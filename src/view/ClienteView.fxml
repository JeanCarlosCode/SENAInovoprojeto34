<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane id="mainPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ClienteController">

    <!-- ==================== HEADER PREMIUM SENAI ==================== -->
    <top>
        <StackPane id="headerPane" style="-fx-padding: 20 40 6 40;">
            <!-- ==================== LADO ESQUERDO: LOGO ==================== -->
            <VBox alignment="CENTER_LEFT" spacing="2" StackPane.alignment="CENTER_LEFT">
                <HBox alignment="BASELINE_LEFT" spacing="12">
                    <Label id="lblLogo" text="SENAI" />
                    <Label id="lblTitulo" text="Cadastro de Clientes" />
                </HBox>
                <Label id="lblSubtitulo" text="Sistema de Gestão de CRM e Frente de Caixa" />
            </VBox>

            <!-- ==================== CENTRO ABSOLUTO: PERFIL ==================== -->
            <VBox alignment="TOP_CENTER" spacing="6" StackPane.alignment="TOP_CENTER" mouseTransparent="true">
                <StackPane fx:id="avatarNavContainer" styleClass="nav-avatar-ring" maxWidth="64" maxHeight="64" minWidth="64" minHeight="64">
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" styleClass="nav-avatar-svg" scaleX="2.0" scaleY="2.0"/>
                </StackPane>
                <VBox alignment="CENTER" spacing="0">
                    <Label fx:id="lblUserName" text="Visitante" styleClass="nav-user-name" />
                    <Label text="Logado" styleClass="nav-user-subtitle" />
                </VBox>
            </VBox>

            <!-- ==================== LADO DIREITO: TEMA E AJUSTES ==================== -->
            <HBox alignment="CENTER_RIGHT" StackPane.alignment="TOP_RIGHT" spacing="6" maxHeight="-Infinity" translateY="-4" translateX="12">
                <Button fx:id="btnTheme" text="Light" onAction="#alternarTema" styleClass="theme-btn" />
                <MenuButton fx:id="btnConfig" text="&#x2699;" id="btnConfig">
                    <items>
                        <MenuItem text="&#x1F464;  Perfil" />
                        <SeparatorMenuItem />
                        <MenuItem text="&#x1F4E6;  Produtos" onAction="#abrirProdutos" />
                        <MenuItem text="&#x1F465;  Clientes" disable="true" />
                        <MenuItem text="&#x1F6D2;  Vendas / PDV" onAction="#abrirVendas" />
                        <SeparatorMenuItem />
                        <MenuItem text="&#x21BA;  Deslogar" onAction="#fazerLogout" />
                        <MenuItem fx:id="menuItemSair" text="&#x1F6AA;  Sair" onAction="#sairApp" />
                    </items>
                </MenuButton>
            </HBox>
        </StackPane>
    </top>

    <!-- ==================== CONTEÚDO CENTRAL ==================== -->
    <center>
        <HBox id="centerPane" spacing="24" alignment="TOP_CENTER">

            <!-- ===== FORMULÁRIO GLASS ==================== -->
            <VBox id="formPane" spacing="10" prefWidth="370" minWidth="350" maxWidth="390">
                <Label id="lblFormTitle" text="Ficha do Cliente" maxWidth="1.7976931348623157E308" />

                <VBox spacing="4">
                    <Label text="Nome Completo *" />
                    <TextField fx:id="txtNome" promptText="Ex: João da Silva" />
                </VBox>
                
                <VBox spacing="4">
                    <Label text="CPF / CNPJ *" />
                    <TextField fx:id="txtDocumento" promptText="Ex: 123.456.789-00" />
                </VBox>

                <HBox spacing="8">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="E-mail" />
                        <TextField fx:id="txtEmail" promptText="joao@email.com" />
                    </VBox>
                </HBox>

                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Telefone" />
                        <TextField fx:id="txtTelefone" promptText="(11) 98765-4321" />
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Status *" />
                        <ComboBox fx:id="cmbStatus" maxWidth="1.7976931348623157E308" />
                    </VBox>
                </HBox>

                <!-- BOTÕES E AÇÕES -->
                <HBox spacing="10" alignment="CENTER" style="-fx-padding: 8 0 0 0;">
                    <Button id="btnLimpar" text="Limpar" onAction="#limpar" />
                    <Button id="btnExcluir" text="Excluir" onAction="#excluir" />
                    <Button id="btnSalvar" text="Salvar" onAction="#salvar" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                </HBox>

                <Region VBox.vgrow="ALWAYS" />
                
                <!-- Histórico de Compras (Painel Inferior) -->
                <VBox spacing="6" style="-fx-border-color: rgba(0,0,0,0.1); -fx-border-radius: 8; -fx-padding: 10;">
                    <Label text="📋 Últimas 5 Compras" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" />
                    <ListView fx:id="listCompras" prefHeight="100" style="-fx-background-color: transparent;" />
                </VBox>

            </VBox>

            <!-- ===== ÁREA DA TABELA ===== -->
            <VBox id="tabelaPane" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" spacing="12">
                
                <!-- Header da Tabela: Titulo + Busca Integrada -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label id="lblTableTitle" text="Carteira de Clientes" minWidth="-Infinity" />
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <HBox id="unifiedSearchPane" alignment="CENTER_LEFT" prefWidth="380">
                        <TextField fx:id="txtBusca" promptText="&#x1F50D; Pesquisar por nome, documento ou email..." HBox.hgrow="ALWAYS" styleClass="search-input" />
                    </HBox>
                </HBox>

                <!-- Tabela -->
                <TableView fx:id="tabelaClientes" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="Vazio. Nenhum cliente cadastrado." />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colId" text="ID" maxWidth="70" minWidth="50" styleClass="col-center" />
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="220" styleClass="col-left" />
                        <TableColumn fx:id="colDocumento" text="CPF / CNPJ" prefWidth="130" styleClass="col-center" />
                        <TableColumn fx:id="colEmail" text="E-mail" prefWidth="180" styleClass="col-left" />
                        <TableColumn fx:id="colTelefone" text="Telefone" prefWidth="120" styleClass="col-center" />
                        <TableColumn fx:id="colStatus" text="Status" maxWidth="100" minWidth="80" styleClass="col-center" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="lblTotal" text="Clientes: 0" />
                </HBox>
            </VBox>

        </HBox>
    </center>

</BorderPane>
